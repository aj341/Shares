# Finnhub (primary real-time provider: quotes, day change) — https://finnhub.io/dashboard
FINNHUB_API_KEY=

# Mboum (history + fundamentals: performance chart, period P&L, targets) — https://mboum.com
MBOUM_API_KEY=

# Data source toggle for quotes: "mock" (default, no keys) | "finnhub"
DATA_SOURCE=mock

# PostgreSQL — when set, the transaction ledger persists to Postgres (production).
# When unset, the app falls back to a local JSON file (data/portfolio-state.json).
# Railway injects this automatically when you attach a Postgres plugin.
DATABASE_URL=

# Optional: set to "disable" if your DB host terminates TLS upstream.
PGSSL=

# Article Impact Analyzer — optional. When set, the analyzer uses Claude for
# deep reasoning; without it, a deterministic heuristic fallback is used.
# (Each analysis makes one Anthropic API call — billed to this key.)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Email alerts (Resend) — optional. When set, the daily alerts cron emails a
# digest. Requires a verified sending domain in Resend for ALERT_EMAIL_FROM.
RESEND_API_KEY=
ALERT_EMAIL_FROM=Shares Alerts <alerts@designbees.com.au>
# Comma-separated; defaults to the three configured addresses if unset.
ALERT_RECIPIENTS=
# Used in the email's "Open dashboard" button + cron protection.
DASHBOARD_URL=https://web-production-ddb43.up.railway.app
CRON_SECRET=

# Telegram near-real-time alerts (optional). Create a bot via @BotFather for the
# token; each recipient messages the bot once, then add their numeric chat IDs
# (comma-separated). The /api/cron/telegram-alerts route sends only new alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=

# Options-implied earnings moves — provider chain (first available wins):
#  1. Mboum Options (upgrade the existing MBOUM_API_KEY plan — no new account)
#  2. Marketdata.app free tier (AU-friendly, 100 req/day): https://www.marketdata.app
#  3. Tradier dev sandbox (US-only signup):
# https://developer.tradier.com -> create account -> sandbox token.
# For a production account set TRADIER_BASE_URL=https://api.tradier.com/v1
MARKETDATA_TOKEN=
TRADIER_TOKEN=
TRADIER_BASE_URL=

# [insider] Insider cluster-buy overlay (SLOW fundamental signal). All optional;
# the overlay uses the existing MBOUM_API_KEY (insider-transactions module) and
# degrades to "none" everywhere when unset. Defaults shown.
INSIDER_MIN_TXN_USD=25000          # ignore transactions below this USD value
INSIDER_CLUSTER_WINDOW_DAYS=30     # window for counting distinct buyers
INSIDER_CLUSTER_MIN_BUYERS=2       # distinct open-market buyers => cluster_buy
INSIDER_BIG_BOSS_BUY_USD=500000    # a single CEO/CFO open-market buy this big => cluster
INSIDER_NOTABLE_BUY_USD=100000     # net open-market buy USD => notable_buy
INSIDER_NOTABLE_SELL_USD=250000    # net open-market sell USD => selling
INSIDER_LOOKBACK_DAYS=120          # only consider filings within this lookback
